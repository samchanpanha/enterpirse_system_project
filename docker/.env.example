# ─── Copy to .env and fill in ──────────────────────────────────────────────
# cp docker/.env.example docker/.env

# ─── Image registry (required for prod push) ───────────────────────────────
# Examples:
#   Docker Hub:  docker.io/myorg
#   GHCR:        ghcr.io/myorg
#   ECR:         123456789012.dkr.ecr.us-east-1.amazonaws.com/myorg
#   GCR:         gcr.io/my-project
REGISTRY=reportsystem

# ─── Image tag (default: latest) ───────────────────────────────────────────
# Use a version (v1.0.0) or git SHA (abc1234) for production.
IMAGE_TAG=latest

# ─── Database (only used by docker-compose.prod.yml) ───────────────────────
DB_PASSWORD=change-me-in-prod

# ─── JWT signing secret (must match across all services) ───────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-min-32-chars-please-use-openssl-rand-base64-48

# ─── Keycloak ──────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── MinIO ─────────────────────────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=change-me-minio-prod

# ─── Payment gateway keys (stubs in dev, real in prod) ────────────────────
ABA_API_KEY=aba-stub-key
ABA_MERCHANT_ID=aba-stub-merchant
WING_API_KEY=wing-stub-key
PI_PAY_API_KEY=pipay-stub-key
